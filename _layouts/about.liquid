---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>
    <p class="desc">{{ page.subtitle }}</p>
  </header>

  <article>
    {% if page.profile %}
      <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
        {% if page.profile.image %}
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1
      rounded' %}
          {% endif %}
          {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px)
      30vw, 95vw"{% endcapture %}
          {%
            include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
            cache_bust=true
          %}
        {% endif %}
        {% if page.profile.more_info %}
          <div class="more-info">{{ page.profile.more_info }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="clearfix">{{ content }}</div>

    <!-- Currently Reading and Listening - inline with last paragraph -->
    {% assign reading_data = site.data.goodreads_reading %}
    {% assign lastfm_data = site.data.lastfm %}
    {% assign has_lastfm = false %}
    {% if lastfm_data and lastfm_data.artist %}
      {% assign has_lastfm = true %}
    {% endif %}
    {% if reading_data and (reading_data.current_book or reading_data.last_read_book) %}
      {% if reading_data.current_book %}
        {% assign reading_lead = " I am currently reading " %}
      {% else %}
        {% assign reading_lead = " I last read " %}
      {% endif %}
      <script>
        (function () {
          function escapeHtml(s) {
            return String(s)
              .replace(/&/g, '&amp;')
              .replace(/</g, '&lt;')
              .replace(/>/g, '&gt;')
              .replace(/"/g, '&quot;');
          }

          function dedupePreservingOrder(items) {
            if (!items || !items.length) return [];
            const seen = new Set();
            const out = [];
            for (let i = 0; i < items.length; i++) {
              if (seen.has(items[i])) continue;
              seen.add(items[i]);
              out.push(items[i]);
            }
            return out;
          }

          function previousTooltipHtml(lines) {
            if (!lines || !lines.length) return null;
            return 'Previously:<br>' + lines.map(escapeHtml).join('<br>');
          }

          document.addEventListener('DOMContentLoaded', function () {
            if (typeof jQuery === 'undefined') return;
            var $ = jQuery;

            const contentDiv = document.querySelector('.clearfix');
            if (!contentDiv) return;
            const paragraphs = contentDiv.querySelectorAll('p');
            if (paragraphs.length === 0) return;
            const lastParagraph = paragraphs[paragraphs.length - 1];

            const bookTitle = {% if reading_data.current_book %}{{ reading_data.current_book.title | jsonify }}{% else %}{{ reading_data.last_read_book.title | jsonify }}{% endif %};
            const bookAuthor = {% if reading_data.current_book %}{% if reading_data.current_book.author %}{{ reading_data.current_book.author | jsonify }}{% else %}null{% endif %}{% else %}{% if reading_data.last_read_book.author %}{{ reading_data.last_read_book.author | jsonify }}{% else %}null{% endif %}{% endif %};

            const previousBookTitles = {{ reading_data.previous_book_titles | jsonify }} || [];
            const hasLastfm = {{ has_lastfm | jsonify }};
            {% if has_lastfm %}
            const previousArtists = {{ lastfm_data.previous_artists | jsonify }} || [];
            const artistName = {{ lastfm_data.artist | jsonify }};
            {% else %}
            const previousArtists = [];
            const artistName = null;
            {% endif %}

            const readingLead = {{ reading_lead | jsonify }};

            const $book = $('<span tabindex="0">').text(bookTitle);
            const bookTip = previousTooltipHtml(previousBookTitles);
            if (bookTip) {
              $book.addClass('reading-hover').attr('style', 'cursor: help; text-decoration: underline dotted;');
              $book.tooltip({ html: true, title: bookTip });
            }

            let $artist = null;
            if (hasLastfm && artistName) {
              const artistLines = dedupePreservingOrder(previousArtists);
              const artistTip = previousTooltipHtml(artistLines);
              $artist = $('<span tabindex="0">').text(artistName);
              if (artistTip) {
                $artist.addClass('reading-hover').attr('style', 'cursor: help; text-decoration: underline dotted;');
                $artist.tooltip({ html: true, title: artistTip });
              }
            }

            $(lastParagraph).append(document.createTextNode(readingLead));
            $(lastParagraph).append($book);
            if (bookAuthor) {
              $(lastParagraph).append(document.createTextNode(' by ' + bookAuthor));
            }
            if ($artist) {
              $(lastParagraph).append(document.createTextNode(' and listening to '));
              $(lastParagraph).append($artist);
            }
            $(lastParagraph).append(document.createTextNode('.'));
          });
        })();
      </script>
    {% endif %}

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">news</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">selected publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% include social.liquid %}</div>

        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
